# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Site URL for CORS and production origin (e.g. https://yourdomain.com)
NEXT_PUBLIC_SITE_URL=http://localhost:5173

# Admin: your email (or comma-separated NEXT_PUBLIC_ADMIN_EMAILS for multiple)
NEXT_PUBLIC_ADMIN_EMAIL=your-email@example.com
